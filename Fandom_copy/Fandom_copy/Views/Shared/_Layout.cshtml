@using Fandom_copy.Localization
@using Fandom_copy.Controllers
@{
    var currentLang = UiText.Normalize(Context.Request.Cookies[SettingsController.LangCookie]);
    var currentTheme = string.IsNullOrWhiteSpace(Context.Request.Cookies[SettingsController.ThemeCookie])
        ? "dark"
        : Context.Request.Cookies[SettingsController.ThemeCookie];
}
<!DOCTYPE html>
<html lang="@currentLang" data-theme="@currentTheme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fandom</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Fandom_copy.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar fandom-nav">
            <div class="container-fluid fandom-nav-row">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">FANDOM<span>HUB</span></a>

                <form class="fandom-search" asp-controller="Posts" asp-action="Search" method="get">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7" /><path d="M21 21l-4.3-4.3" /></svg>
                    <input type="search" name="q" placeholder="@UiText.T(currentLang, "nav.search.placeholder")" value="@Context.Request.Query["q"]" />
                </form>

                <div class="nav-account">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Account" asp-action="Profile">@User.Identity.Name</a>
                        <form asp-controller="Account" asp-action="Logout" method="post"><button type="submit">@UiText.T(currentLang, "nav.logout")</button></form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login">@UiText.T(currentLang, "nav.login")</a>
                        <a class="nav-join" asp-controller="Account" asp-action="Register">@UiText.T(currentLang, "nav.register")</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="fandom-shell">
        <aside class="fandom-sidebar">
            <a asp-controller="Home" asp-action="Index" title="@UiText.T(currentLang, "sidebar.home")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 11.5 12 4l9 7.5" /><path d="M5 10v10h14V10" /></svg>
                <span>@UiText.T(currentLang, "sidebar.home")</span>
            </a>
            <a asp-controller="Posts" asp-action="Index" title="@UiText.T(currentLang, "sidebar.posts")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Posts" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="7" height="7" rx="1.5" /><rect x="13" y="4" width="7" height="7" rx="1.5" /><rect x="4" y="13" width="7" height="7" rx="1.5" /><rect x="13" y="13" width="7" height="7" rx="1.5" /></svg>
                <span>@UiText.T(currentLang, "sidebar.posts")</span>
            </a>
            <a asp-controller="Categories" asp-action="Index" title="@UiText.T(currentLang, "sidebar.categories")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l9 5-9 5-9-5 9-5z" /><path d="M3 13l9 5 9-5" /></svg>
                <span>@UiText.T(currentLang, "sidebar.categories")</span>
            </a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Posts" asp-action="Saved" title="@UiText.T(currentLang, "sidebar.saved")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Posts" && ViewContext.RouteData.Values["action"]?.ToString() == "Saved" ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1z" /></svg>
                    <span>@UiText.T(currentLang, "sidebar.saved")</span>
                </a>
            }
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Index" title="@UiText.T(currentLang, "sidebar.admin")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l7 4v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V7z" /><path d="M9 12l2 2 4-5" /></svg>
                    <span>@UiText.T(currentLang, "sidebar.admin")</span>
                </a>
            }
            <a asp-controller="Home" asp-action="Privacy" title="@UiText.T(currentLang, "sidebar.rules")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Privacy" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z" /></svg>
                <span>@UiText.T(currentLang, "sidebar.rules")</span>
            </a>
            <a asp-controller="Settings" asp-action="Index" title="@UiText.T(currentLang, "sidebar.settings")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1.04 1.56V21a2 2 0 1 1-4 0v-.09A1.7 1.7 0 0 0 9 19.4a1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-1.56-1.04H3a2 2 0 1 1 0-4h.09A1.7 1.7 0 0 0 4.6 9a1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.7 1.7 0 0 0 9 4.6a1.7 1.7 0 0 0 1.04-1.56V3a2 2 0 1 1 4 0v.09A1.7 1.7 0 0 0 15 4.6a1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.7 1.7 0 0 0 19.4 9a1.7 1.7 0 0 0 1.56 1.04H21a2 2 0 1 1 0 4h-.09A1.7 1.7 0 0 0 19.4 15z" /></svg>
                <span>@UiText.T(currentLang, "sidebar.settings")</span>
            </a>
        </aside>

        <div class="fandom-main">
            <div class="container">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>

            <footer class="border-top footer text-muted">
                <div class="container">
                    &copy; 2026 FandomHub · @UiText.T(currentLang, "footer.rights")
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
