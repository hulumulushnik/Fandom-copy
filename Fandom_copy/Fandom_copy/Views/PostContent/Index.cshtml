@using Fandom_copy.DTOs.Posts
@using Fandom_copy.Models
@using Fandom_copy.Services
@model PostContentEditorDto
@{
    ViewData["Title"] = "Структура публікації";
    var containerId = Model.ContainerSectionId;
    string SizeName(PostTextSize s) => s switch {
        PostTextSize.Small => "малий",
        PostTextSize.Large => "великий",
        PostTextSize.Heading => "заголовок",
        _ => "звичайний"
    };
    string AlignName(PostTextAlign a) => a switch {
        PostTextAlign.Center => "по центру",
        PostTextAlign.Right => "праворуч",
        _ => "ліворуч"
    };
    string StyleName(PostTextStyle s) => s switch {
        PostTextStyle.BulletList => "маркований список",
        PostTextStyle.NumberedList => "нумерований список",
        PostTextStyle.Quote => "цитата",
        _ => "абзац"
    };
    string DisplayName(PostSectionDisplayStyle s) => s switch {
        PostSectionDisplayStyle.CenteredCard => "по центру",
        PostSectionDisplayStyle.LeftCard => "ліворуч",
        PostSectionDisplayStyle.RightCard => "праворуч",
        PostSectionDisplayStyle.TextLink => "текст-посилання",
        PostSectionDisplayStyle.CompactRow => "компактний рядок",
        _ => "картка з іконкою"
    };
    string GalleryStyleName(PostGalleryStyle s) => s switch {
        PostGalleryStyle.Masonry => "мозаїка",
        PostGalleryStyle.Carousel => "карусель",
        PostGalleryStyle.Strip => "стрічка",
        _ => "сітка"
    };
    string TemplateName(PostBlockTemplateType t) => PostContentFormatting.TemplateLabel(t);
}

<nav class="wiki-back">
    @if (containerId is null)
    {
        <a asp-controller="Posts" asp-action="Details" asp-route-id="@Model.PostId">← до публікації</a>
    }
    else
    {
        <a asp-controller="PostSections" asp-action="Details" asp-route-postId="@Model.PostId" asp-route-id="@containerId">← до підпоста</a>
    }
</nav>

<section class="structure-shell">
    <div class="structure-heading">
        <div>
            <p class="wiki-kicker">Редактор сторінки</p>
            <h1>Структура: @Model.Title</h1>
            <p>Збирайте сторінку: вступ, галерея, картки розділів і вкладені сторінки.</p>
        </div>
        <a class="btn btn-primary" asp-controller="PostSections" asp-action="Create" asp-route-postId="@Model.PostId" asp-route-parentSectionId="@containerId">+ Створити підпост</a>
    </div>

    @if (TempData["Error"] is string error) { <div class="alert alert-danger">@error</div> }

    <div class="fandom-toolbelt">
        <div>
            <strong>Перетягуйте блоки мишею</strong>
            <span>Форматування зберігається структуровано й не допускає довільний HTML.</span>
        </div>
        <div class="toolbelt-pills">
            <span>Rich text</span>
            <span>Templates</span>
            <span>Gallery</span>
        </div>
    </div>

    <div class="structure-grid">
        <section class="structure-list js-block-list"
                 data-reorder-url="@(containerId is null
                     ? Url.Action("Reorder", "PostContent", new { postId = Model.PostId })
                     : Url.Action("Reorder", "PostContent", new { postId = Model.PostId, sectionId = containerId }))">
            @Html.AntiForgeryToken()
            @if (!Model.Blocks.Any())
            {
                <div class="empty-structure">
                    <strong>Сторінка поки порожня.</strong>
                    <span>Додайте перший текст, фото, шаблон або підпост через панель інструментів.</span>
                </div>
            }

            @for (var i = 0; i < Model.Blocks.Count; i++)
            {
                var block = Model.Blocks[i];
                var previewClasses = string.Join(' ',
                    PostContentFormatting.TextSizeClass(block.TextSize),
                    PostContentFormatting.TextAlignClass(block.TextAlign),
                    PostContentFormatting.TextStyleClass(block.TextStyle),
                    PostContentFormatting.TextColorClass(block.TextColor));
                <article class="structure-block js-block" draggable="true" data-block-id="@block.Id">
                    <div class="structure-block-bar">
                        <span class="drag-handle" title="Перетягнути">⋮⋮</span>
                        <span class="structure-order">#@(i + 1)</span>
                        <span class="badge text-bg-secondary">@block.Type</span>
                        <div class="structure-controls">
                            <form asp-action="Move" asp-route-postId="@Model.PostId" asp-route-sectionId="@containerId" asp-route-id="@block.Id" asp-route-direction="-1" method="post">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-secondary" title="Вище" disabled="@(i == 0)">↑</button>
                            </form>
                            <form asp-action="Move" asp-route-postId="@Model.PostId" asp-route-sectionId="@containerId" asp-route-id="@block.Id" asp-route-direction="1" method="post">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-secondary" title="Нижче" disabled="@(i == Model.Blocks.Count - 1)">↓</button>
                            </form>
                            <form asp-action="Delete" asp-route-postId="@Model.PostId" asp-route-sectionId="@containerId" asp-route-id="@block.Id" method="post" onsubmit="return confirm('Прибрати цей блок зі структури?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" title="Прибрати">×</button>
                            </form>
                        </div>
                    </div>

                    @if (block.Type == PostContentBlockType.Text || block.Type == PostContentBlockType.Template)
                    {
                        var isTemplate = block.Type == PostContentBlockType.Template;
                        <form asp-action="UpdateText" asp-route-postId="@Model.PostId" asp-route-sectionId="@containerId" asp-route-id="@block.Id" method="post" class="structure-edit-form js-rich-form">
                            @Html.AntiForgeryToken()
                            <label class="form-label">
                                @(isTemplate ? $"Шаблон: {TemplateName(block.TemplateType)}" : "Текстовий блок")
                            </label>

                            <div class="rich-toolbar" role="toolbar" aria-label="Форматирование">
                                <button type="button" class="rt-btn js-rt-toggle" data-target="NewTextBold" title="Жирний"><b>Ж</b></button>
                                <button type="button" class="rt-btn js-rt-toggle" data-target="NewTextItalic" title="Курсив"><i>К</i></button>
                                <button type="button" class="rt-btn js-rt-toggle" data-target="NewTextUnderline" title="Підкреслений"><u>П</u></button>
                                <button type="button" class="rt-btn js-rt-toggle" data-target="NewTextStrike" title="Закреслений"><s>З</s></button>
                                <select name="NewTextSize" class="form-select form-select-sm" title="Розмір">
                                    @foreach (var s in Enum.GetValues<PostTextSize>())
                                    {
                                        <option value="@((int)s)" selected="@(s == block.TextSize)">@SizeName(s)</option>
                                    }
                                </select>
                                <select name="NewTextAlign" class="form-select form-select-sm" title="Вирівнювання">
                                    @foreach (var a in Enum.GetValues<PostTextAlign>())
                                    {
                                        <option value="@((int)a)" selected="@(a == block.TextAlign)">@AlignName(a)</option>
                                    }
                                </select>
                                <select name="NewTextStyle" class="form-select form-select-sm" title="Стиль">
                                    @foreach (var st in Enum.GetValues<PostTextStyle>())
                                    {
                                        <option value="@((int)st)" selected="@(st == block.TextStyle)">@StyleName(st)</option>
                                    }
                                </select>
                                <select name="NewTextColor" class="form-select form-select-sm" title="Колір">
                                    <option value="" selected="@string.IsNullOrEmpty(block.TextColor)">за замовчуванням</option>
                                    @foreach (var c in PostContentFormatting.AllowedTextColors.Where(c => c != "default"))
                                    {
                                        <option value="@c" selected="@(string.Equals(block.TextColor, c, StringComparison.OrdinalIgnoreCase))">@c</option>
                                    }
                                </select>
                                <input type="hidden" name="NewTextBold" value="@(block.TextBold ? "true" : "false")" data-rt-flag />
                                <input type="hidden" name="NewTextItalic" value="@(block.TextItalic ? "true" : "false")" data-rt-flag />
                                <input type="hidden" name="NewTextUnderline" value="@(block.TextUnderline ? "true" : "false")" data-rt-flag />
                                <input type="hidden" name="NewTextStrike" value="@(block.TextStrike ? "true" : "false")" data-rt-flag />
                            </div>

                            <textarea name="text" rows="5" class="form-control js-rt-source">@block.Text</textarea>

                            <div class="rt-preview @previewClasses">
                                <div class="js-rt-preview">@block.Text</div>
                            </div>

                            <button class="btn btn-sm btn-outline-primary mt-2">Зберегти</button>
                        </form>
                    }
                    else if (block.Type == PostContentBlockType.Image)
                    {
                        <div class="structure-image-row">
                            <img src="@Url.Content(block.ImagePath)" alt="@(string.IsNullOrWhiteSpace(block.ImageCaption) ? "Зображення" : block.ImageCaption)" />
                            <form asp-action="UpdateImageCaption" asp-route-postId="@Model.PostId" asp-route-sectionId="@containerId" asp-route-id="@block.Id" method="post" class="structure-edit-form">
                                @Html.AntiForgeryToken()
                                <label class="form-label">Підпис до фото</label>
                                <input name="imageCaption" value="@block.ImageCaption" maxlength="240" class="form-control" />
                                <button class="btn btn-sm btn-outline-primary mt-2">Зберегти підпис</button>
                            </form>
                        </div>
                    }
                    else if (block.Type == PostContentBlockType.Gallery)
                    {
                        <div class="structure-gallery-editor">
                            <form asp-action="UpdateGallery" asp-route-postId="@Model.PostId" asp-route-sectionId="@containerId" asp-route-id="@block.Id" method="post" class="structure-edit-form">
                                @Html.AntiForgeryToken()
                                <label class="form-label">Галерея (@block.GalleryImages.Count шт.)</label>
                                <div class="row g-2">
                                    <div class="col-md-8">
                                        <input name="galleryCaption" value="@block.GalleryCaption" maxlength="240" class="form-control" placeholder="Підпис галереї" />
                                    </div>
                                    <div class="col-md-4">
                                        <select name="galleryStyle" class="form-select">
                                            @foreach (var g in Enum.GetValues<PostGalleryStyle>())
                                            {
                                                <option value="@((int)g)" selected="@(g == block.GalleryStyle)">@GalleryStyleName(g)</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="gallery-editor-grid js-gallery-sort" data-order-input="#OrderedImages-@block.Id">
                                    @foreach (var img in block.GalleryImages.OrderBy(i => i.Order))
                                    {
                                        <div class="gallery-editor-thumb" draggable="true" data-image-id="@img.Id">
                                            <img src="@Url.Content(img.ImagePath)" alt="" />
                                            <button type="submit"
                                                    formaction="@Url.Action("DeleteGalleryImage", "PostContent", new { postId = Model.PostId, sectionId = containerId, id = block.Id, imageId = img.Id })"
                                                    formmethod="post"
                                                    class="btn btn-sm btn-outline-danger"
                                                    title="Видалити">×</button>
                                        </div>
                                    }
                                </div>
                                <input type="hidden" id="OrderedImages-@block.Id" name="orderedImageIds" value="@string.Join(',', block.GalleryImages.OrderBy(i => i.Order).Select(i => i.Id))" />
                                <button class="btn btn-sm btn-outline-primary mt-2">Зберегти галерею</button>
                            </form>
                        </div>
                    }
                    else if (block.Type == PostContentBlockType.Section)
                    {
                        <div class="structure-section-link">
                            <span class="wiki-topic-placeholder">!</span>
                            <div style="flex:1">
                                <strong>@(block.SectionTitle ?? "Підпост")</strong>
                                <p>Картка-перехід у підпост. Видалення прибере картку зі структури, сам підпост залишиться.</p>
                                <form asp-action="UpdateSectionDisplay" asp-route-postId="@Model.PostId" asp-route-sectionId="@containerId" asp-route-id="@block.Id" method="post" class="structure-edit-form">
                                    @Html.AntiForgeryToken()
                                    <div class="row g-2">
                                        <div class="col-md-6">
                                            <label class="form-label">Стиль відображення</label>
                                            <select name="displayStyle" class="form-select js-display-select">
                                                @foreach (var d in Enum.GetValues<PostSectionDisplayStyle>())
                                                {
                                                    <option value="@((int)d)" selected="@(d == block.SectionDisplayStyle)">@DisplayName(d)</option>
                                                }
                                            </select>
                                            <small class="text-muted">Як картку буде показано відвідувачу.</small>
                                        </div>
                                        <div class="col-md-6 js-textlink-input" data-visible-when="@((int)PostSectionDisplayStyle.TextLink)">
                                            <label class="form-label">Текст посилання (необов’язково)</label>
                                            <input name="linkText" value="@block.SectionLinkText" maxlength="240" class="form-control" placeholder="@block.SectionTitle" />
                                            <small class="text-muted">Порожньо — використовується назва підпоста.</small>
                                        </div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-primary mt-2">Зберегти</button>
                                </form>
                            </div>
                        </div>
                    }
                </article>
            }
        </section>

        <aside class="structure-tools">
            <form asp-action="AddText" asp-route-postId="@Model.PostId" asp-route-sectionId="@containerId" method="post" class="tool-card js-rich-form">
                @Html.AntiForgeryToken()
                <h2>+ Текст</h2>

                <div class="rich-toolbar" role="toolbar" aria-label="Форматирование">
                    <button type="button" class="rt-btn js-rt-toggle" data-target="NewTextBold" title="Жирний"><b>Ж</b></button>
                    <button type="button" class="rt-btn js-rt-toggle" data-target="NewTextItalic" title="Курсив"><i>К</i></button>
                    <button type="button" class="rt-btn js-rt-toggle" data-target="NewTextUnderline" title="Підкреслений"><u>П</u></button>
                    <button type="button" class="rt-btn js-rt-toggle" data-target="NewTextStrike" title="Закреслений"><s>З</s></button>
                    <select asp-for="NewTextSize" class="form-select form-select-sm" title="Розмір">
                        @foreach (var s in Enum.GetValues<PostTextSize>())
                        {
                            <option value="@((int)s)">@SizeName(s)</option>
                        }
                    </select>
                    <select asp-for="NewTextAlign" class="form-select form-select-sm" title="Вирівнювання">
                        @foreach (var a in Enum.GetValues<PostTextAlign>())
                        {
                            <option value="@((int)a)">@AlignName(a)</option>
                        }
                    </select>
                    <select asp-for="NewTextStyle" class="form-select form-select-sm" title="Стиль">
                        @foreach (var st in Enum.GetValues<PostTextStyle>())
                        {
                            <option value="@((int)st)">@StyleName(st)</option>
                        }
                    </select>
                    <select asp-for="NewTextColor" class="form-select form-select-sm" title="Колір">
                        <option value="">за замовчуванням</option>
                        @foreach (var c in PostContentFormatting.AllowedTextColors.Where(c => c != "default"))
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                    <input type="hidden" asp-for="NewTextBold" data-rt-flag />
                    <input type="hidden" asp-for="NewTextItalic" data-rt-flag />
                    <input type="hidden" asp-for="NewTextUnderline" data-rt-flag />
                    <input type="hidden" asp-for="NewTextStrike" data-rt-flag />
                </div>

                <textarea asp-for="NewText" rows="5" id="NewText" class="form-control js-rt-source" placeholder="Абзац, опис, правила, вступ..."></textarea>

                <div class="rt-preview">
                    <div class="js-rt-preview">Тут з’явиться попередній перегляд форматування.</div>
                </div>

                <button class="btn btn-outline-primary mt-2">Додати текст</button>
            </form>

            <form asp-action="AddImage" asp-route-postId="@Model.PostId" asp-route-sectionId="@containerId" method="post" enctype="multipart/form-data" class="tool-card">
                @Html.AntiForgeryToken()
                <h2>+ Фото</h2>
                <input type="file" name="imageFiles" accept="image/png,image/jpeg,image/gif,image/webp" multiple class="form-control js-image-input" data-preview="#structureImagePreview" />
                <input asp-for="NewImageCaption" maxlength="240" class="form-control mt-2" placeholder="Підпис під фото" />
                <small class="text-muted">JPG, PNG, GIF або WEBP до 5 МБ.</small>
                <div id="structureImagePreview" class="image-preview-grid"></div>
                <button class="btn btn-outline-primary mt-2">Загрузить фото</button>
            </form>

            <form asp-action="AddGallery" asp-route-postId="@Model.PostId" asp-route-sectionId="@containerId" method="post" enctype="multipart/form-data" class="tool-card">
                @Html.AntiForgeryToken()
                <h2>+ Галерея</h2>
                <input type="file" name="galleryFiles" accept="image/png,image/jpeg,image/gif,image/webp" multiple class="form-control js-image-input" data-preview="#galleryImagePreview" />
                <div class="row g-2 mt-2">
                    <div class="col-md-7">
                        <input asp-for="NewGalleryCaption" maxlength="240" class="form-control" placeholder="Спільний підпис" />
                    </div>
                    <div class="col-md-5">
                        <select asp-for="NewGalleryStyle" class="form-select">
                            @foreach (var g in Enum.GetValues<PostGalleryStyle>())
                            {
                                <option value="@((int)g)">@GalleryStyleName(g)</option>
                            }
                        </select>
                    </div>
                </div>
                <div id="galleryImagePreview" class="image-preview-grid"></div>
                <button class="btn btn-outline-primary mt-2">Создать галерею</button>
            </form>

            <div class="tool-card">
                <h2>+ Шаблон</h2>
                <p class="text-muted small">Готові блоки: інфобокс, попередження, факт, лор тощо. Можна редагувати як звичайний текст.</p>
                <div class="template-picker">
                    @foreach (var t in Enum.GetValues<PostBlockTemplateType>().Where(x => x != PostBlockTemplateType.None))
                    {
                        <form asp-action="AddTemplate" asp-route-postId="@Model.PostId" asp-route-sectionId="@containerId" method="post" class="template-picker-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="templateType" value="@((int)t)" />
                            <button class="template-chip" type="submit" title="@TemplateName(t)">@TemplateName(t)</button>
                        </form>
                    }
                </div>
            </div>

            <form asp-action="AddExistingSection" asp-route-postId="@Model.PostId" asp-route-sectionId="@containerId" method="post" class="tool-card js-section-picker-form">
                @Html.AntiForgeryToken()
                <h2>+ Підпост в структуру</h2>
                @if (Model.AvailableSections.Any())
                {
                    <select name="linkedSectionId" class="form-select">
                        @foreach (var availableSection in Model.AvailableSections)
                        {
                            <option value="@availableSection.Id">@availableSection.Title</option>
                        }
                    </select>
                    <label class="form-label mt-2">Стиль відображення</label>
                    <select name="displayStyle" class="form-select js-display-select">
                        @foreach (var d in Enum.GetValues<PostSectionDisplayStyle>())
                        {
                            <option value="@((int)d)">@DisplayName(d)</option>
                        }
                    </select>
                    <div class="section-display-hints">
                        <small class="text-muted">
                            Картка з іконкою — як раніше. По центру / ліворуч / праворуч — виділяє підпост.
                            Текст-посилання — просто гіперпосилання. Компактний рядок — маленька іконка + назва.
                        </small>
                    </div>
                    <div class="mt-2 js-textlink-input" data-visible-when="@((int)PostSectionDisplayStyle.TextLink)">
                        <label class="form-label">Текст посилання (для режиму «текст-посилання»)</label>
                        <input name="linkText" maxlength="240" class="form-control" placeholder="Залиште порожнім, щоб використати назву" />
                    </div>
                    <button class="btn btn-outline-primary mt-2">Вставить</button>
                }
                else
                {
                    <p class="text-muted mb-0">Усі підпости цього рівня вже вставлено. Можна створити новий.</p>
                }
            </form>
        </aside>
    </div>
</section>

@section Scripts {
    <script src="~/js/post-content-editor.js" asp-append-version="true"></script>
}
