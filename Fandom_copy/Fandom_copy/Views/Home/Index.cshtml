@using Fandom_copy.DTOs.Home
@model HomeViewModel
@{
    var currentLang = UiText.Normalize(Context.Request.Cookies[SettingsController.LangCookie]);
    ViewData["Title"] = UiText.T(currentLang, "home.title");
}

<section class="home-section">
    <div class="home-section-heading">
        <h2>@(Model.JumpBackInIsSaved ? UiText.T(currentLang, "home.jump_back") : UiText.T(currentLang, "home.recent"))</h2>
        @if (Model.JumpBackInIsSaved)
        {
            <a asp-controller="Posts" asp-action="Saved" class="home-view-all">@UiText.T(currentLang, "home.all_saved")</a>
        }
        else
        {
            <a asp-controller="Posts" asp-action="Index" class="home-view-all">@UiText.T(currentLang, "home.all_posts")</a>
        }
    </div>

    @if (!Model.JumpBackIn.Any())
    {
        <p class="text-muted">@UiText.T(currentLang, "home.empty") <a asp-controller="Posts" asp-action="Create">@UiText.T(currentLang, "home.create_first")</a></p>
    }
    else
    {
        <div class="home-jump-grid">
            @foreach (var c in Model.JumpBackIn)
            {
                <a class="home-jump-card" asp-controller="Posts" asp-action="Details" asp-route-id="@c.Id">
                    <div class="home-jump-thumb">
                        @if (!string.IsNullOrWhiteSpace(c.CoverImagePath))
                        {
                            <img src="@Url.Content(c.CoverImagePath)" alt="@c.Title" />
                        }
                        else
                        {
                            <span class="wiki-topic-placeholder">@c.Title.Substring(0, 1).ToUpper()</span>
                        }
                    </div>
                    <div class="home-jump-info">
                        <strong>@c.Title</strong>
                        <small>@(c.CategoryName ?? "—")</small>
                    </div>
                </a>
            }
        </div>
    }
</section>

@if (Model.RecentPosts.Any())
{
    <section class="home-section">
        <div class="home-section-heading">
            <h2>@UiText.T(currentLang, "home.recent_posts")</h2>
        </div>
        <div class="home-recent-row">
            @foreach (var c in Model.RecentPosts)
            {
                <a class="home-recent-circle" asp-controller="Posts" asp-action="Details" asp-route-id="@c.Id" title="@c.Title">
                    <span class="home-recent-avatar">
                        @if (!string.IsNullOrWhiteSpace(c.CoverImagePath))
                        {
                            <img src="@Url.Content(c.CoverImagePath)" alt="@c.Title" />
                        }
                        else
                        {
                            @c.Title.Substring(0, 1).ToUpper()
                        }
                    </span>
                    <span class="home-recent-title">@c.Title</span>
                </a>
            }
        </div>
    </section>
}

@if (Model.Categories.Any())
{
    <section class="home-section">
        <div class="home-section-heading">
            <h2>@UiText.T(currentLang, "home.categories_to_open")</h2>
        </div>
        <div class="home-category-grid">
            @foreach (var cat in Model.Categories)
            {
                <a class="home-category-card" asp-controller="Categories" asp-action="Details" asp-route-id="@cat.Id">
                    <div class="home-category-cover">
                        @if (!string.IsNullOrWhiteSpace(cat.CoverImagePath))
                        {
                            <img src="@Url.Content(cat.CoverImagePath)" alt="@cat.Name" />
                        }
                        else
                        {
                            <span class="wiki-topic-placeholder">@cat.Name.Substring(0, 1).ToUpper()</span>
                        }
                    </div>
                    <div class="home-category-info">
                        <strong>@cat.Name</strong>
                        <small>@cat.PostCount @UiText.T(currentLang, "posts.count_suffix")</small>
                    </div>
                </a>
            }
        </div>
    </section>
}
