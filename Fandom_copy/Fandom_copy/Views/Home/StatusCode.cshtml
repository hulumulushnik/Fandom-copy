@{
    var code = ViewBag.StatusCode is int statusCode ? statusCode : 500;
    var title = code switch
    {
        403 => "Доступ заборонено",
        404 => "Сторінку не знайдено",
        500 => "Помилка сервера",
        _ => "Сталася помилка"
    };
    var message = code switch
    {
        403 => "У вас немає прав для перегляду цього розділу.",
        404 => "Ми не знайшли сторінку, яку ви шукаєте.",
        500 => "Під час обробки запиту сталася помилка.",
        _ => "Запит завершився з неочікуваним статусом."
    };

    ViewData["Title"] = $"{code} — {title}";
}

<section class="account-shell status-page-shell">
    <div class="empty-structure status-page-card">
        <p class="status-kicker">FandomHub</p>
        <div class="status-code">@code</div>
        <h1>@title</h1>
        <p class="status-message">@message</p>
        <a class="primary-btn status-home-btn" href="/">На головну</a>
    </div>
</section>

<style>
    .status-page-shell {
        min-height: calc(100vh - 170px);
        padding: 54px 18px;
    }

    .status-page-card {
        width: min(100%, 640px);
        margin: 0 auto;
        padding: 52px 28px;
        background:
            radial-gradient(circle at top, #35285f 0, transparent 48%),
            linear-gradient(145deg, #171b33, #101528);
        border: 1px solid #303658;
        border-radius: 22px;
        box-shadow: 0 24px 70px #0007;
        color: #e9eaf4;
    }

    .status-kicker {
        margin: 0;
        color: #a98cff;
        font-size: .78rem;
        font-weight: 900;
        letter-spacing: .18em;
        text-transform: uppercase;
    }

    .status-code {
        margin: 4px 0 10px;
        color: #fff7ec;
        font-size: clamp(5rem, 16vw, 10rem);
        font-weight: 950;
        line-height: .95;
        text-shadow: 0 8px 0 #0008;
    }

    .status-page-card h1 {
        margin: 0;
        color: #fff;
        font-size: clamp(1.6rem, 4vw, 2.35rem);
        font-weight: 900;
    }

    .status-message {
        max-width: 430px;
        margin: 14px auto 8px;
        color: #c7cbda;
        font-size: 1.05rem;
    }

    .status-home-btn {
        margin-top: 20px;
    }
</style>
