@using Fandom_copy.DTOs.Posts
@model UpdatePostSectionDto
@{
    ViewData["Title"] = "Редагувати підпост";
    var postId = (Guid)ViewBag.PostId;
    var sectionId = (Guid)ViewBag.SectionId;
}

<h1>Редагувати підпост</h1>

<form asp-action="Edit" asp-route-postId="@postId" asp-route-id="@sectionId" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label">Заголовок</label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Text" class="form-label">Текст</label>
        <textarea asp-for="Text" class="form-control" rows="12"></textarea>
        <span asp-validation-for="Text" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Order" class="form-label">Порядок</label>
        <input asp-for="Order" type="number" class="form-control" />
        <span asp-validation-for="Order" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Зберегти</button>
    <a asp-controller="PostSections" asp-action="Details"
       asp-route-postId="@postId" asp-route-id="@sectionId"
       class="btn btn-outline-secondary">Скасувати</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
