@using Fandom_copy.DTOs.Posts
@using Fandom_copy.Models
@using Fandom_copy.Services
@model PostSectionDto
@{
    var post = ViewBag.Post as PostDto;
    ViewData["Title"] = Model.Title;
    var canEdit = post?.CanEdit ?? false;
    var subSectionLookup = Model.SubSections.ToDictionary(s => s.Id);
}

<nav class="wiki-back">
    <a asp-controller="Posts" asp-action="Details" asp-route-id="@Model.PostId">← @(post?.Title ?? "Публикация")</a>
    @foreach (var crumb in Model.Breadcrumbs)
    {
        <span>/</span>
        <a asp-action="Details" asp-route-postId="@Model.PostId" asp-route-id="@crumb.Id">@crumb.Title</a>
    }
</nav>

<section class="wiki-hero wiki-hero-compact">
    <div class="wiki-kicker">Под-пост</div>
    <h1>@Model.Title</h1>
    @if (canEdit)
    {
        <div class="wiki-actions">
            <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-postId="@Model.PostId" asp-route-id="@Model.Id">Редактировать</a>
            <a class="btn btn-outline-primary" asp-controller="PostContent" asp-action="Index" asp-route-postId="@Model.PostId" asp-route-sectionId="@Model.Id">Структура</a>
            <a class="btn btn-primary" asp-action="Create" asp-route-postId="@Model.PostId" asp-route-parentSectionId="@Model.Id">+ Под-пост</a>
        </div>
    }
</section>

@if (Model.ContentBlocks.Any())
{
    var orderedBlocks = Model.ContentBlocks.OrderBy(b => b.Order).ToList();
    <article class="wiki-content">
        @{
            await Html.RenderPartialAsync("/Views/Posts/_ContentBlocks.cshtml", new Fandom_copy.Views.Posts.ContentBlocksModel {
                Blocks = orderedBlocks,
                SectionLookup = subSectionLookup,
                PostId = Model.PostId,
                FallbackTitle = Model.Title
            });
        }
    </article>
}
else
{
    <article class="wiki-content">
        <div class="wiki-copy">@Model.Text</div>
        @if (!Model.SubSections.Any())
        {
            <p class="text-muted">Пока нет вложенных под-постов.</p>
        }
        else
        {
            <div class="wiki-topic-grid">
                @foreach (var sub in Model.SubSections.OrderBy(x => x.Order))
                {
                    <a class="wiki-topic-card" asp-action="Details" asp-route-postId="@Model.PostId" asp-route-id="@sub.Id">
                        <span class="wiki-topic-art">
                            @if (!string.IsNullOrWhiteSpace(sub.IconPath ?? sub.PrimaryImagePath))
                            {
                                <img src="@Url.Content(sub.IconPath ?? sub.PrimaryImagePath)" alt="@sub.Title" />
                            }
                            else
                            {
                                <span class="wiki-topic-placeholder">!</span>
                            }
                        </span>
                        <strong>@sub.Title</strong>
                        <small>Открыть →</small>
                    </a>
                }
            </div>
        }
    </article>
}

@if (Model.Attachments.Any())
{
    <section class="wiki-content">
        <div class="wiki-attachments-block">
            <div class="wiki-attachments-heading">
                <span class="wiki-kicker">Файли</span>
                <h2>Прикріплені файли</h2>
            </div>
            <div class="attachment-list">
                @foreach (var file in Model.Attachments)
                {
                    <a class="attachment-item attachment-link" href="@Url.Content(file.Path)" download>
                        <span class="attachment-icon">FILE</span>
                        <span class="attachment-meta">
                            <strong>@file.FileName</strong>
                            <small>@FormatFileSize(file.Size)</small>
                        </span>
                    </a>
                }
            </div>
        </div>
    </section>
}

@functions {
    private static string FormatFileSize(long bytes)
    {
        const double kiloByte = 1024d;
        const double megaByte = kiloByte * 1024d;

        if (bytes >= megaByte)
            return $"{bytes / megaByte:0.#} МБ";

        return $"{Math.Max(bytes / kiloByte, 0.1):0.#} КБ";
    }
}
