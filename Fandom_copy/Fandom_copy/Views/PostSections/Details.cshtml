@using Fandom_copy.DTOs.Posts
@model PostSectionDto
@{
    var post = ViewBag.Post as PostDto;
    ViewData["Title"] = Model.Title;
    var canEdit = post?.CanEdit ?? false;
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}
@if (TempData["Message"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Posts" asp-action="Index">Пости</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Posts" asp-action="Details" asp-route-id="@Model.PostId">
                @(post?.Title ?? "Пост")
            </a>
        </li>
        @foreach (var crumb in Model.Breadcrumbs)
        {
            <li class="breadcrumb-item">
                <a asp-controller="PostSections" asp-action="Details"
                   asp-route-postId="@Model.PostId" asp-route-id="@crumb.Id">@crumb.Title</a>
            </li>
        }
        <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-start">
    <h1>@Model.Title</h1>
    @if (canEdit)
    {
        <div class="btn-group">
            <a class="btn btn-outline-secondary"
               asp-controller="PostSections" asp-action="Edit"
               asp-route-postId="@Model.PostId" asp-route-id="@Model.Id">Редагувати</a>
            <a class="btn btn-primary"
               asp-controller="PostSections" asp-action="Create"
               asp-route-postId="@Model.PostId" asp-route-parentSectionId="@Model.Id">+ Підпост</a>
            <form asp-controller="PostSections" asp-action="Delete"
                  asp-route-postId="@Model.PostId" asp-route-id="@Model.Id"
                  method="post" class="d-inline"
                  onsubmit="return confirm('Видалити підпост і всі вкладені?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">Видалити</button>
            </form>
        </div>
    }
</div>

<article class="mt-3 mb-4" style="white-space:pre-wrap;">
    @Model.Text
</article>

<hr />

<h4>Вкладені підпости</h4>
@if (!Model.SubSections.Any())
{
    <p class="text-muted">Тут ще немає вкладених підпостів.</p>
}
else
{
    <div class="list-group mb-3">
        @foreach (var sub in Model.SubSections.OrderBy(x => x.Order))
        {
            <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
               asp-controller="PostSections" asp-action="Details"
               asp-route-postId="@Model.PostId" asp-route-id="@sub.Id">
                <span><strong>@sub.Title</strong></span>
                <small class="text-muted">#@sub.Order</small>
            </a>
        }
    </div>
}
