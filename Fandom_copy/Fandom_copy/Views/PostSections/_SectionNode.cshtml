@using Fandom_copy.DTOs.Posts
@model PostSectionDto
@{
    var currentLang = UiText.Normalize(Context.Request.Cookies[SettingsController.LangCookie]);
    var postId = (Guid)ViewData["PostId"]!;
    var depth = (int)(ViewData["Depth"] ?? 0);
    var marginLeft = depth * 12;
}

<div class="border-start ps-3 mb-3" style="margin-left:@(marginLeft)px;">
    <div class="d-flex justify-content-between align-items-start">
        <h4>@Model.Title</h4>
        @if (User?.Identity?.IsAuthenticated == true)
        {
            <div class="btn-group btn-group-sm">
                <a class="btn btn-outline-secondary"
                   asp-controller="PostSections" asp-action="Edit"
                   asp-route-postId="@postId" asp-route-id="@Model.Id">@UiText.T(currentLang, "section.edit")</a>
                <a class="btn btn-outline-primary"
                   asp-controller="PostSections" asp-action="Create"
                   asp-route-postId="@postId" asp-route-parentSectionId="@Model.Id">@UiText.T(currentLang, "section.add_subpost")</a>
                <form asp-controller="PostSections" asp-action="Delete"
                      asp-route-postId="@postId" asp-route-id="@Model.Id"
                      method="post" class="d-inline"
                      onsubmit="return confirm('@UiText.T(currentLang, "section.delete_confirm")');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger">@UiText.T(currentLang, "section.delete")</button>
                </form>
            </div>
        }
    </div>
    <div style="white-space:pre-wrap;">@Model.Text</div>

    @foreach (var sub in Model.SubSections)
    {
        <partial name="_SectionNode" model="sub"
                 view-data='new ViewDataDictionary(ViewData) { ["PostId"] = postId, ["Depth"] = depth + 1 }' />
    }
</div>
