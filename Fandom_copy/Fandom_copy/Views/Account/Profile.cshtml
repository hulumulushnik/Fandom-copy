@model Fandom_copy.DTOs.Profile.UserProfileDto
@{ ViewData["Title"] = "My profile"; }
<section class="profile-shell"><div class="profile-heading"><div class="avatar">@Model.Login[..1].ToUpper()</div><div><p class="eyebrow">MY ACCOUNT</p><h1>@Model.Login</h1><p class="muted">Member since @Model.RegistrationDate.ToString("MMMM yyyy") · @Model.GlobalRole</p></div></div>@if (TempData["Success"] is string message) { <div class="notice success">@message</div> }<div class="profile-grid"><article class="profile-card"><h2>Profile details</h2><form method="post"><div asp-validation-summary="ModelOnly" class="form-error"></div><label for="Login">Username</label><input id="Login" name="Login" value="@Model.Login"/><label for="Email">Email</label><input id="Email" name="Email" type="email" value="@Model.Email"/><p class="verification @(Model.EmailConfirmed ? "verified" : "unverified")">@(Model.EmailConfirmed ? "Email verified" : "Email not verified")</p><button class="primary-btn">Save changes</button></form></article><aside class="profile-card security-card"><h2>Security</h2><p class="muted">Keep your account secure with a unique password.</p><a class="secondary-btn" asp-action="ChangePassword">Change password</a><hr/><h3>Account role</h3><p class="role-pill">@Model.GlobalRole</p></aside></div></section>
