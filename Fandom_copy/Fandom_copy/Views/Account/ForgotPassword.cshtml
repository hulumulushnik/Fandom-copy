@model Fandom_copy.DTOs.Auth.ForgotPasswordRequestDto
@{ ViewData["Title"] = "Reset password"; }
<section class="account-shell"><div class="account-card"><p class="eyebrow">ACCOUNT RECOVERY</p><h1>Reset your password</h1><p class="muted">We’ll email you a secure reset link.</p><form method="post"><div asp-validation-summary="ModelOnly" class="form-error"></div><label asp-for="Email">Email</label><input asp-for="Email" autocomplete="email"/><span asp-validation-for="Email"></span><button class="primary-btn">Send reset link</button></form><p class="account-footer"><a asp-action="Login">Back to sign in</a></p></div></section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
