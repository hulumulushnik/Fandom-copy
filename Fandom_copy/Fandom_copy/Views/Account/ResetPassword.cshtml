@model Fandom_copy.DTOs.Auth.ResetPasswordRequestDto
@{ ViewData["Title"] = "Choose new password"; }
<section class="account-shell"><div class="account-card"><p class="eyebrow">ACCOUNT RECOVERY</p><h1>Choose a new password</h1><form method="post"><input asp-for="Email" type="hidden"/><input asp-for="Token" type="hidden"/><div asp-validation-summary="ModelOnly" class="form-error"></div><label asp-for="NewPassword">New password</label><input asp-for="NewPassword" type="password" autocomplete="new-password"/><span asp-validation-for="NewPassword"></span><label asp-for="ConfirmNewPassword">Confirm new password</label><input asp-for="ConfirmNewPassword" type="password" autocomplete="new-password"/><span asp-validation-for="ConfirmNewPassword"></span><button class="primary-btn">Save password</button></form></div></section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
