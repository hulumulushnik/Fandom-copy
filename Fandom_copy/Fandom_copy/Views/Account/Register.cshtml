@model Fandom_copy.DTOs.Auth.RegisterRequestDto
@{ ViewData["Title"] = "Create account"; }
<section class="account-shell"><div class="account-card"><p class="eyebrow">FANDOM</p><h1>Create your account</h1><p class="muted">Join the community and start building your game worlds.</p><form method="post" novalidate><div asp-validation-summary="ModelOnly" class="form-error"></div><label asp-for="Login">Username</label><input asp-for="Login" autocomplete="username"/><span asp-validation-for="Login"></span><label asp-for="Email">Email</label><input asp-for="Email" autocomplete="email"/><span asp-validation-for="Email"></span><label asp-for="Password">Password</label><input asp-for="Password" type="password" autocomplete="new-password"/><span asp-validation-for="Password"></span><label asp-for="ConfirmPassword">Confirm password</label><input asp-for="ConfirmPassword" type="password" autocomplete="new-password"/><span asp-validation-for="ConfirmPassword"></span><button type="submit" class="primary-btn">Create account</button></form><p class="account-footer">Already have an account? <a asp-action="Login">Sign in</a></p></div></section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
