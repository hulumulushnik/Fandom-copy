@model Fandom_copy.DTOs.Auth.LoginRequestDto
@{
    ViewData["Title"] = "Sign in";
    var externalProviders = ViewData["ExternalProviders"] as string[] ?? Array.Empty<string>();
}

<section class="account-shell">
    <div class="account-card">
        <p class="eyebrow">FANDOM</p>
        <h1>Welcome back</h1>
        <p class="muted">Sign in to continue creating and discussing.</p>

        @if (TempData["Success"] is string message)
        {
            <div class="notice success">@message</div>
        }

        @if (TempData["Error"] is string error)
        {
            <div class="notice error">@error</div>
        }

        @if (externalProviders.Length > 0)
        {
            <div class="external-auth">
                <p>Continue with</p>
                @foreach (var provider in externalProviders)
                {
                    <form asp-action="ExternalLogin" method="post">
                        <input type="hidden" name="provider" value="@provider" />
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                        <button type="submit" class="oauth-btn @provider.ToLowerInvariant()">
                            @if (provider == "Google")
                            {
                                <svg viewBox="0 0 20 20" width="19" height="19" aria-hidden="true">
                                    <path fill="#4285F4" d="M19.6 10.23c0-.68-.06-1.32-.17-1.94H10v3.68h5.38a4.6 4.6 0 0 1-2 3.02v2.5h3.23c1.9-1.75 2.99-4.32 2.99-7.26Z" />
                                    <path fill="#34A853" d="M10 20c2.7 0 4.96-.9 6.61-2.43l-3.23-2.5c-.9.6-2.04.96-3.38.96-2.6 0-4.8-1.76-5.59-4.12H1.06v2.59A10 10 0 0 0 10 20Z" />
                                    <path fill="#FBBC05" d="M4.41 11.9a5.99 5.99 0 0 1 0-3.8V5.51H1.06a10 10 0 0 0 0 8.98l3.35-2.6Z" />
                                    <path fill="#EA4335" d="M10 3.98c1.47 0 2.79.5 3.83 1.5l2.87-2.87A9.6 9.6 0 0 0 10 0 10 10 0 0 0 1.06 5.51l3.35 2.6C5.2 5.75 7.4 3.98 10 3.98Z" />
                                </svg>
                                <span>Continue with Google</span>
                            }
                            else if (provider == "Facebook")
                            {
                                <svg viewBox="0 0 24 24" width="19" height="19" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.9h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94Z" /></svg>
                                <span>Continue with Facebook</span>
                            }
                            else
                            {
                                <span>@provider</span>
                            }
                        </button>
                    </form>
                }
            </div>
            <div class="divider"><span>or</span></div>
        }

        <form method="post" novalidate>
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <div asp-validation-summary="ModelOnly" class="form-error"></div>
            <label asp-for="LoginOrEmail">Username or email</label>
            <input asp-for="LoginOrEmail" autocomplete="username" />
            <span asp-validation-for="LoginOrEmail"></span>
            <label asp-for="Password">Password</label>
            <input asp-for="Password" type="password" autocomplete="current-password" />
            <span asp-validation-for="Password"></span>
            <label class="check"><input asp-for="RememberMe" /> Keep me signed in</label>
            <button type="submit" class="primary-btn">Sign in</button>
        </form>

        <div class="account-links">
            <a asp-action="ForgotPassword">Forgot password?</a>
            <a asp-action="ResendConfirmation">Resend confirmation</a>
        </div>
        <p class="account-footer">New here? <a asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]">Create account</a></p>
    </div>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
