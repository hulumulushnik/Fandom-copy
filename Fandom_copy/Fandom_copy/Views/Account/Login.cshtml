@model Fandom_copy.DTOs.Auth.LoginRequestDto
@{ ViewData["Title"] = "Sign in"; }
<section class="account-shell"><div class="account-card"><p class="eyebrow">FANDOM</p><h1>Welcome back</h1><p class="muted">Sign in to continue creating and discussing.</p>@if (TempData["Success"] is string message) { <div class="notice success">@message</div> }<form method="post" novalidate><input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]"/><div asp-validation-summary="ModelOnly" class="form-error"></div><label asp-for="LoginOrEmail">Username or email</label><input asp-for="LoginOrEmail" autocomplete="username"/><span asp-validation-for="LoginOrEmail"></span><label asp-for="Password">Password</label><input asp-for="Password" type="password" autocomplete="current-password"/><span asp-validation-for="Password"></span><label class="check"><input asp-for="RememberMe"/> Keep me signed in</label><button type="submit" class="primary-btn">Sign in</button></form><div class="account-links"><a asp-action="ForgotPassword">Forgot password?</a><a asp-action="ResendConfirmation">Resend confirmation</a></div><p class="account-footer">New here? <a asp-action="Register">Create account</a></p></div></section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
