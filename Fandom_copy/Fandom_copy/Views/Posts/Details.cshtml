@using Fandom_copy.DTOs.Posts
@using Fandom_copy.Models
@using Fandom_copy.Services
@model PostDto
@{
    ViewData["Title"] = Model.Title;
    var sectionLookup = Model.Sections.ToDictionary(s => s.Id);
    var postVersions = ViewBag.PostVersions as List<PostVersionDto> ?? new List<PostVersionDto>();
}

<nav class="wiki-back"><a asp-controller="Posts" asp-action="Index">← К публикациям</a></nav>

@if (TempData["Error"] is string err) { <div class="alert alert-danger">@err</div> }
@if (TempData["Message"] is string msg) { <div class="alert alert-success">@msg</div> }

@if (Model.Author is not null)
{
    var authorFrameClass = "frame-" + Model.Author.ProfileFrameName.ToLowerInvariant();
    <a class="post-author-card" asp-controller="Account" asp-action="PublicProfile" asp-route-login="@Model.Author.Login">
        <span class="profile-avatar-frame post-author-frame @authorFrameClass">
            @if (!string.IsNullOrWhiteSpace(Model.Author.AvatarUrl))
            {
                <img src="@Url.Content(Model.Author.AvatarUrl)" alt="@Model.Author.Login" class="profile-avatar-img" />
            }
            else
            {
                <span class="avatar">@Model.Author.Login[..1].ToUpper()</span>
            }
        </span>
        <span class="post-author-meta">
            <small>Автор поста</small>
            <strong>@Model.Author.Login</strong>
        </span>
    </a>
}

<section class="wiki-hero">
    <div class="wiki-kicker">@(Model.CategoryName ?? "Fandom page") · @(Model.IsPublic ? "Публичная" : "Приватная")</div>
    <h1>Welcome to the <em>@Model.Title</em> Wiki!</h1>
    @if (Model.TagNames.Any())
    {
        <div class="post-row-meta wiki-tag-list">
            @foreach (var tag in Model.TagNames)
            {
                <span class="post-tag">@tag</span>
            }
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p>@Model.Description</p>
    }
    <div class="wiki-actions">
        @if (User?.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="Posts" asp-action="ToggleSave" asp-route-id="@Model.Id" method="post">
                @{ bool isSaved = ViewBag.IsSaved is true; }
                <button type="submit" class="btn @(isSaved ? "btn-outline-warning" : "btn-outline-secondary") save-btn">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="@(isSaved ? "currentColor" : "none")" stroke="currentColor" stroke-width="2"><path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1z" /></svg>
                    @(isSaved ? "Збережено" : "Зберегти")
                </button>
            </form>
        }
        @if (User?.Identity?.IsAuthenticated == true && Model.CanEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Редактировать</a>
            <a asp-controller="PostContent" asp-action="Index" asp-route-postId="@Model.Id" class="btn btn-outline-primary">Структура</a>
            <a asp-controller="PostSections" asp-action="Create" asp-route-postId="@Model.Id" class="btn btn-primary">+ Под-пост</a>
        }
    </div>
</section>

@if (Model.CanManageMembers)
{
    <section class="wiki-content">
        <div class="post-version-panel">
            <div class="post-version-heading">
                <div>
                    <span class="wiki-kicker">Owner tools</span>
                    <h2>Откат поста</h2>
                </div>
                <small>Версии создаются автоматически перед изменениями редакторов.</small>
            </div>
            @if (postVersions.Any())
            {
                <div class="post-version-list">
                    @foreach (var version in postVersions)
                    {
                        <div class="post-version-item">
                            <div>
                                <strong>@version.Action</strong>
                                <small>@version.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm") · @version.UserLogin</small>
                            </div>
                            <form asp-action="RestoreVersion"
                                  asp-route-id="@Model.Id"
                                  asp-route-versionId="@version.Id"
                                  method="post"
                                  onsubmit="return confirm('Відкотити пост до цієї версії? Поточний стан також буде збережено як резервну версію.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-warning">Відкотити</button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Попередніх версій поки немає.</p>
            }
        </div>
    </section>
}

@if (Model.ContentBlocks.Any())
{
    var orderedBlocks = Model.ContentBlocks.OrderBy(b => b.Order).ToList();
    <article class="wiki-content">
        @{
            await Html.RenderPartialAsync("_ContentBlocks", new Fandom_copy.Views.Posts.ContentBlocksModel {
                Blocks = orderedBlocks,
                SectionLookup = sectionLookup,
                PostId = Model.Id,
                FallbackTitle = Model.Title
            });
        }
    </article>
}
else
{
    <article class="wiki-content">
        <div class="wiki-copy">@Model.Description</div>
        @if (!Model.Sections.Any())
        {
            <p class="text-muted">Под-постов пока нет.</p>
        }
        else
        {
            <div class="wiki-topic-grid">
                @foreach (var s in Model.Sections.OrderBy(x => x.Order))
                {
                    <a class="wiki-topic-card" asp-controller="PostSections" asp-action="Details" asp-route-postId="@Model.Id" asp-route-id="@s.Id">
                        <span class="wiki-topic-art">
                            @if (!string.IsNullOrWhiteSpace(s.IconPath ?? s.PrimaryImagePath))
                            {
                                <img src="@Url.Content(s.IconPath ?? s.PrimaryImagePath)" alt="@s.Title" />
                            }
                            else
                            {
                                <span class="wiki-topic-placeholder">!</span>
                            }
                        </span>
                        <strong>@s.Title</strong>
                        <small>Открыть →</small>
                    </a>
                }
            </div>
        }
    </article>
}
