@using Fandom_copy.DTOs.Posts
@model PostDto
@{
    ViewData["Title"] = Model.Title;
}

<nav class="mb-3">
    <a asp-controller="Posts" asp-action="Index">← До списку</a>
</nav>

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}
@if (TempData["Message"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}

<div class="d-flex justify-content-between align-items-center">
    <div>
        <h1>@Model.Title</h1>
        <p class="text-muted">
            Категорія: @(Model.CategoryName ?? "—")
            · @(Model.IsPublic ? "Публічний" : "Приватний")
            · Створено: @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")
            · Оновлено: @Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm")
            @if (Model.CurrentUserRole is not null)
            {
                <span>· Ваша роль: <strong>@Model.CurrentUserRole</strong></span>
            }
        </p>
    </div>
    @if (User?.Identity?.IsAuthenticated == true && Model.CanEdit)
    {
        <div class="btn-group">
            <a asp-controller="Posts" asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-outline-secondary">Редагувати пост</a>
            <a asp-controller="PostSections" asp-action="Create" asp-route-postId="@Model.Id"
               class="btn btn-primary">+ Підпост</a>
            @if (Model.CanManageMembers)
            {
                <a asp-controller="Posts" asp-action="Members" asp-route-id="@Model.Id"
                   class="btn btn-outline-info">Учасники</a>
                <form asp-controller="Posts" asp-action="Delete" asp-route-id="@Model.Id"
                      method="post" class="d-inline"
                      onsubmit="return confirm('Видалити пост?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger">Видалити пост</button>
                </form>
            }
        </div>
    }
</div>

<hr />
<div class="mb-4" style="white-space:pre-wrap;">@Model.Description</div>

<h3>Підпости</h3>
@if (!Model.Sections.Any())
{
    <p class="text-muted">Підпостів ще немає.</p>
}
else
{
    <div class="list-group mb-3">
        @foreach (var s in Model.Sections.OrderBy(x => x.Order))
        {
            <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
               asp-controller="PostSections" asp-action="Details"
               asp-route-postId="@Model.Id" asp-route-id="@s.Id">
                <span>
                    <strong>@s.Title</strong>
                </span>
                <small class="text-muted">#@s.Order</small>
            </a>
        }
    </div>
}
