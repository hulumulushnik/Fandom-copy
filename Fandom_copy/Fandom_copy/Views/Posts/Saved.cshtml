@using Fandom_copy.DTOs.Posts
@model List<PostDto>
@{
    var currentLang = UiText.Normalize(Context.Request.Cookies[SettingsController.LangCookie]);
    ViewData["Title"] = UiText.T(currentLang, "saved.title");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <p class="wiki-kicker">@UiText.T(currentLang, "saved.kicker")</p>
        <h1 class="mb-0">@UiText.T(currentLang, "saved.title")</h1>
    </div>
    <a asp-controller="Posts" asp-action="Index" class="btn btn-outline-secondary">@UiText.T(currentLang, "home.all_posts")</a>
</div>

@if (TempData["Error"] is string err) { <div class="alert alert-danger">@err</div> }
@if (TempData["Message"] is string msg) { <div class="alert alert-success">@msg</div> }

@if (!Model.Any())
{
    <p class="text-muted">@UiText.T(currentLang, "saved.empty")</p>
}
else
{
    <div class="list-group">
        @foreach (var p in Model)
        {
            <div class="list-group-item saved-item">
                <a asp-controller="Posts" asp-action="Details" asp-route-id="@p.Id" class="saved-item-link">
                    <div class="d-flex w-100 justify-content-between">
                        <h5 class="mb-1">@p.Title</h5>
                        <small class="text-muted">@p.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                    </div>
                    <p class="mb-1">@p.Description</p>
                    <small class="text-muted">
                        @UiText.T(currentLang, "saved.category_label"): @(p.CategoryName ?? "—")
                        @(p.IsPublic ? "· " + UiText.T(currentLang, "posts.public") : "· " + UiText.T(currentLang, "posts.private"))
                    </small>
                </a>
                <form asp-controller="Posts" asp-action="ToggleSave" asp-route-id="@p.Id" method="post" class="saved-item-unsave">
                    <button type="submit" class="btn btn-sm btn-outline-danger">@UiText.T(currentLang, "saved.remove")</button>
                </form>
            </div>
        }
    </div>
}
