@using Fandom_copy.DTOs.Posts
@model List<PostDto>
@{
    ViewData["Title"] = "Пости";
}

<div class="posts-heading">
    <div>
        <p class="wiki-kicker">Спільнота FandomHub</p>
        <h1>Пости</h1>
    </div>
    @if (User?.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Posts" asp-action="Create" class="btn btn-primary">+ Створити пост</a>
    }
</div>

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}
@if (TempData["Message"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}

@if (!Model.Any())
{
    <div class="empty-structure">
        <strong>Постів ще немає</strong>
        <span>Станьте першим — створіть пост і почніть наповнювати вікі.</span>
    </div>
}
else
{
    <div class="posts-list">
        @foreach (var p in Model)
        {
            var cover = !string.IsNullOrWhiteSpace(p.IconPath)
                ? p.IconPath
                : p.ContentBlocks
                    .Where(b => b.Type == PostContentBlockType.Image)
                    .OrderBy(b => b.Order)
                    .Select(b => b.ImagePath)
                    .FirstOrDefault();

            <a asp-controller="Posts" asp-action="Details" asp-route-id="@p.Id" class="post-row">
                <div class="post-row-thumb">
                    @if (!string.IsNullOrWhiteSpace(cover))
                    {
                        <img src="@Url.Content(cover)" alt="@p.Title" />
                    }
                    else
                    {
                        <span class="wiki-topic-placeholder">@p.Title.Substring(0, 1).ToUpper()</span>
                    }
                </div>
                <div class="post-row-body">
                    <div class="post-row-top">
                        <h5>@p.Title</h5>
                        <small class="post-row-date">@p.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(p.Description))
                    {
                        <p class="post-row-desc">@p.Description</p>
                    }
                    <div class="post-row-meta">
                        <span class="post-tag">@(p.CategoryName ?? "—")</span>
                        <span class="post-tag @(p.IsPublic ? "post-tag-public" : "post-tag-private")">
                            @(p.IsPublic ? "Публічний" : "Приватний")
                        </span>
                    </div>
                </div>
            </a>
        }
    </div>
}
