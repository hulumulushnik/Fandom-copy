@using Fandom_copy.DTOs.Posts
@model List<PostDto>
@{
    ViewData["Title"] = "Пости";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Пости</h1>
    @if (User?.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Posts" asp-action="Create" class="btn btn-primary">Створити пост</a>
    }
</div>

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}
@if (TempData["Message"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}

@if (!Model.Any())
{
    <p class="text-muted">Постів ще немає.</p>
}
else
{
    <div class="list-group">
        @foreach (var p in Model)
        {
            <a asp-controller="Posts" asp-action="Details" asp-route-id="@p.Id"
               class="list-group-item list-group-item-action">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1">@p.Title</h5>
                    <small class="text-muted">@p.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                </div>
                <p class="mb-1">@p.Description</p>
                <small class="text-muted">
                    Категорія: @(p.CategoryName ?? "—")
                    @(p.IsPublic ? "· Публічний" : "· Приватний")
                </small>
            </a>
        }
    </div>
}
